# ==============================================================================
# Project Alpha Environment Variables Configuration Example
# ==============================================================================
# Rename this file to .env to load variables locally. Do not commit .env.

# System Runtime Mode (development, testing, staging, production)
ALPHA_ENV=development

# Log Configuration (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Application Core Configuration
# Maximum allowable slippage rate for transaction execution (e.g. 0.005 = 0.5%)
MAX_SLIPPAGE_RATE=0.005

# Risk parameters
MAX_PORTFOLIO_DRAWDOWN=0.15
