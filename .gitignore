# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nosetests/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
.project
.pydevproject
.settings/

# OS-specific
Thumbs.db
Desktop.ini
.DS_Store

# Project Alpha Local Storage
storage/raw/*
!storage/raw/.gitkeep
storage/processed/*
!storage/processed/.gitkeep
storage/cache/*
!storage/cache/.gitkeep
storage/exports/*
!storage/exports/.gitkeep
storage/reports/*
!storage/reports/.gitkeep
